# For LOCAL development: copy this file to .env and fill in your keys.
# On Vercel, set these in Project → Settings → Environment Variables instead.

# Gemini — study content generation. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ElevenLabs — podcast audio generation. Get a key at https://elevenlabs.io (Profile → API Keys)
ELEVENLABS_API_KEY=

# Firebase — login, profiles and document history. Get these from your Firebase
# project's Settings → Service accounts → Generate new private key (backend/secret).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional: change models/voices/limits without touching code
# GEMINI_MODEL=gemini-2.5-flash
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_VOICE_HOST_A=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_VOICE_HOST_B=pNInz6obpgDQGcFmaJgB
# DAILY_USAGE_LIMIT=5

# Firebase web config — from your Firebase project's Settings → General →
# Your apps → Web app. These are public identifiers (safe to expose in the
# browser bundle), unlike the backend secrets above.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
