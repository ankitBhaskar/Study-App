# For LOCAL development: copy this file to .env and fill in your keys.
# On Vercel, set these in Project → Settings → Environment Variables instead.

# Gemini — study content generation. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ElevenLabs — podcast audio generation. Get a key at https://elevenlabs.io (Profile → API Keys)
ELEVENLABS_API_KEY=

# Optional: change models/voices without touching code
# GEMINI_MODEL=gemini-2.5-flash
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_VOICE_HOST_A=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_VOICE_HOST_B=pNInz6obpgDQGcFmaJgB
