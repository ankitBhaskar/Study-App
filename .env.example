# For LOCAL development: copy this file to .env and fill in your keys.
# On Vercel, set these in Project → Settings → Environment Variables instead.

# Gemini — study content generation. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Podcast audio uses Gemini TTS by default (cheaper, reuses GEMINI_API_KEY).
# ElevenLabs is only needed if you set TTS_PROVIDER=elevenlabs below.
# Get an ElevenLabs key at https://elevenlabs.io (Profile → API Keys).
ELEVENLABS_API_KEY=

# Firebase — login, profiles and document history. Get these from your Firebase
# project's Settings → Service accounts → Generate new private key (backend/secret).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Restrict sign-in to specific accounts (comma-separated). Leave empty to
# allow anyone who signs in with a valid account for this Firebase project.
# The frontend has no public sign-up form, but this is the real enforcement:
# it applies no matter how a Firebase account was created.
ALLOWED_EMAILS=

# Podcast text-to-speech backend: "google" (default — Cloud Text-to-Speech,
# Neural2 voice, whole episode in one fast call), "gemini" or "elevenlabs".
# "google" needs the Cloud TTS API enabled on the key's Google Cloud project:
# https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# (reuses GEMINI_API_KEY unless GOOGLE_TTS_API_KEY is set; Neural2 is
# $16/1M chars, WaveNet $4/1M, both with ~1M free chars/month).
# TTS_PROVIDER=google
# GOOGLE_TTS_VOICE=en-US-Neural2-F
# GOOGLE_TTS_API_KEY=

# Optional: change models/voices/limits without touching code
# GEMINI_MODEL=gemini-2.5-flash
# Gemini TTS model + the two prebuilt host voices (Kore, Puck, Charon, Fenrir,
# Aoede, Leda, Orus, Zephyr, … — see Gemini's speech-generation docs)
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE_A=Kore
# GEMINI_TTS_VOICE_B=Puck
# Podcast audio is generated in batches of consecutive segments totalling at
# most this many spoken characters per Gemini call (a full 4,500-char script
# is too much audio to synthesize inside one serverless request).
# GEMINI_TTS_BATCH_CHARS=2250
# GEMINI_TTS_TIMEOUT_SECONDS=280
# ElevenLabs (only used when TTS_PROVIDER=elevenlabs)
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_VOICE_HOST_A=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_VOICE_HOST_B=pNInz6obpgDQGcFmaJgB
# DAILY_USAGE_LIMIT=100

# Firebase web config — from your Firebase project's Settings → General →
# Your apps → Web app. These are public identifiers (safe to expose in the
# browser bundle), unlike the backend secrets above.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
