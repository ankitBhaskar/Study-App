# Add only the providers you want to test.
GEMINI_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# Optional model overrides.
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
OPENAI_TTS_MODEL=gpt-4o-mini-tts
